<Frame id="rec_root" direction="vertical" width="max" height="max" padding="10">
    <Frame direction="horizontal" width="max" height="min" margin_bottom="6">
        <Frame direction="vertical" width="max" height="min" margin_right="6">
            <Label id="lbl_record_name" text="Name" font_style="Bold" height="min" margin_bottom="2"/>
            <Edit id="record_name" width="max" height="28" placeholder="www" labelled_by="lbl_record_name"/>
        </Frame>
        <Frame direction="vertical" width="130" height="min">
            <Label id="lbl_record_type" text="Type" font_style="Bold" height="min" margin_bottom="2"/>
            <ComboBox id="record_type" width="max" height="28" text="A" labelled_by="lbl_record_type"/>
        </Frame>
    </Frame>
    <Frame direction="horizontal" width="max" height="min" margin_bottom="6">
        <Frame direction="vertical" width="max" height="min" margin_right="6">
            <Label id="lbl_record_ttl" text="TTL" font_style="Bold" height="min" margin_bottom="2"/>
            <Edit id="record_ttl" width="max" height="28" filter="numeric" text="3600" labelled_by="lbl_record_ttl"/>
        </Frame>
        <Frame direction="vertical" width="max" height="min" margin_right="6">
            <Label id="lbl_record_priority" text="Priority" font_style="Bold" height="min" margin_bottom="2"/>
            <Edit id="record_priority" width="max" height="28" filter="numeric" placeholder="10" labelled_by="lbl_record_priority"/>
        </Frame>
        <Frame direction="vertical" width="max" height="min" margin_right="6">
            <Label id="lbl_record_weight" text="Weight" font_style="Bold" height="min" margin_bottom="2"/>
            <Edit id="record_weight" width="max" height="28" filter="numeric" placeholder="10" labelled_by="lbl_record_weight"/>
        </Frame>
        <Frame direction="vertical" width="max" height="min">
            <Label id="lbl_record_port" text="Port" font_style="Bold" height="min" margin_bottom="2"/>
            <Edit id="record_port" width="max" height="28" filter="numeric" placeholder="5222" labelled_by="lbl_record_port"/>
        </Frame>
    </Frame>
    <Label id="lbl_record_data" text="Data/host" font_style="Bold" height="min" margin_bottom="2"/>
    <Edit id="record_data" width="max" height="28" placeholder="1.2.3.4" margin_bottom="10" labelled_by="lbl_record_data"/>
    <Frame width="max" height="max"/>
    <Frame direction="horizontal" width="max" height="min">
        <Frame width="max" height="min"/>
        <Button id="btn_add" text="Add" height="28" margin_right="4"/>
        <Button id="btn_cancel" text="Cancel" height="28"/>
    </Frame>
</Frame>
